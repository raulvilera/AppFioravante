{
    "headers": [
        {
            "source": "/(sw.js|manifest.json)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                },
                {
                    "key": "Service-Worker-Allowed",
                    "value": "/"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/((?!pwa-.*|sw.js|manifest.json|assets/|index.css).*)",
            "destination": "/index.html"
        }
    ]
}